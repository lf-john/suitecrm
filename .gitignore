# Environment and secrets
.env
env.example

# Logs
*.log
logs/

# Uploads (user data, not code)
suitecrm/upload/*
!suitecrm/upload/.gitkeep

# Database dumps — never track SQL in git (store externally: S3, Drive, etc.)
*.sql
backups/

# Angular build cache
suitecrm/.angular/

# SuiteCRM cache (regenerated by Quick Repair & Rebuild)
suitecrm/cache/
suitecrm/public/legacy/cache/

# Temporary files
suitecrm/tmp/

# Vendor dependencies (installed via composer)
suitecrm/vendor/

# Node modules
suitecrm/node_modules/

# Export archives
*.tar.gz

# OS files
.DS_Store
Thumbs.db
docker/nginx/ssl/
